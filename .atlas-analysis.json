  "keyFeatures": [
    "RAG-based financial Q&A with semantic data source routing",
    "Earnings transcript search with hybrid vector + keyword search",
    "SEC 10-K filings retrieval with 91% accuracy on FinanceBench",
    "Real-time financial news integration via Tavily",
    "Iterative self-improvement with quality evaluation",
    "Multi-ticker comparative analysis with parallel processing",
    "Natural language financial screener (in development)",
    "FastAPI REST endpoints with streaming responses"
  ],
  "publicApiSurface": [
    "POST /message/stream-v2 - Chat with streaming RAG responses",
    "GET /companies/search - Search companies by ticker/name",
    "GET /transcript/{ticker}/{year}/{quarter} - Get earnings transcript",
    "POST /screener/query/stream - Natural language financial queries",
    "Agent class - Main RAG agent orchestrator",
    "RAGAgent.execute_rag_flow() - Execute RAG pipeline",
    "create_agent() - Factory function for agent creation",
    "SearchEngine.search_similar_chunks() - Hybrid transcript search",
    "SECFilingsService - SEC 10-K retrieval agent",
    "TavilyService - Real-time news search"
  ]
